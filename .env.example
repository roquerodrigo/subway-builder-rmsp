# RMSP build configuration — copy to `.env` and uncomment/edit to override.
#
#   cp .env.example .env
#
# Every value here is the built-in default from src/rmsp/config.py; a real shell
# `export` still wins over this file. Only scalar knobs are env-overridable — the
# dict/tuple/set knobs (bbox, special-demand POIs, ...) live in config.py.
# Booleans: 0/false/no = off, anything else = on.

# --- city ------------------------------------------------------------------
# RMSP_CODE=RMSP
# RMSP_NAME=São Paulo
# RMSP_DESCRIPTION=Região Metropolitana de São Paulo com demanda real da Pesquisa Origem-Destino do Metrô-SP.
# RMSP_POPULATION=22800000
# RMSP_CENTER_LAT=-23.5505
# RMSP_CENTER_LNG=-46.6333
# RMSP_ZOOM=9
# RMSP_MIN_ZOOM=8

# --- build -----------------------------------------------------------------
# Worker processes for per-feature passes. 0 = auto (all but one core); 1 = in-process.
# RMSP_BUILD_WORKERS=0

# --- buildings -------------------------------------------------------------
# Min building footprint (m²): depot's building_index_filter_size.
# deg->m scale used by the straight-line routing metric.
# RMSP_BLDG_AREA_MIN_M2=120.0
# RMSP_M_PER_DEG_LAT=110900.0
# RMSP_M_PER_DEG_LNG=101900.0

# --- depot generation (non-demand files: roads/buildings/airports/ocean/pmtiles) ---
# All map 1:1 to depot.maps.MapGen inputs.
# RMSP_MAXZOOM=15
# RMSP_BUILDING_SIMPLIFY_M=1.0
# RMSP_BUILDING_FOUNDATIONS=1
# RMSP_OCEAN_FOUNDATIONS=1
# RMSP_MAPSHAPER_RAM_GB=4.0
# RMSP_MAX_BUILDING_TILE_KB=450   # per-tile building cap; 0 = no cap (depot 1.2.x default)

# --- demand (baixada da release do demand-data; não gerada aqui) -----------
# URL do asset demand_data.json.gz publicado no subway-builder-rmsp-demand-data.
# RMSP_DEMAND_URL=https://github.com/roquerodrigo/subway-builder-rmsp-demand-data/releases/download/v1.0.0/demand_data.json.gz
# pontos de demanda especiais (aeroporto, parque, estádio, …) — ver rmsp/specials.py.
# RMSP_SPECIAL_DEMAND=1

# --- routing (OSRM) --------------------------------------------------------
# RMSP_OSRM_PORT=5050
# RMSP_ROUTE_WORKERS=16
# RMSP_PATH_SIMPLIFY_EPS=0.0008
# Toggle: linha reta entre os pontos (pula o OSRM; near-instant, sem geometria de via).
# RMSP_ROUTE_STRAIGHT_LINE=false
# Velocidade média (km/h) p/ converter distância em linha reta em drivingSeconds.
# RMSP_ROUTE_STRAIGHT_SPEED_KMH=30

# --- download URLs ---------------------------------------------------------
# RMSP_GEOFABRIK_PBF_URL=https://download.geofabrik.de/south-america/brazil/sudeste-latest.osm.pbf
